<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.WhatsappCloneTwo">

        <service
            android:name=".services.Produtos"
            android:enabled="true"
            android:exported="true" />
        <service
            android:name=".services.Contatos"
            android:enabled="true"
            android:exported="true" />

        <activity
            android:name=".activities.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activities.MainActivity"
            android:exported="true" />
        <activity
            android:name=".activities.ConfigActivity"
            android:exported="false" />
        <activity
            android:name=".activities.RegisterActivity"
            android:exported="false" />
        <activity
            android:name=".activities.ForgotPasswordActivity"
            android:exported="false" />
        <activity
            android:name=".activities.ItemDetailActivity"
            android:exported="false" />
        <activity
            android:name=".activities.UsersAllListActivity"
            android:exported="false" />
    </application>

</manifest>